# ── Model API keys ────────────────────────────────────────────────────────────
# One key per connection defined in models.yaml.
# The variable name must match the "api_key_env" field for that connection.

ANTHROPIC_API_KEY=
AZURE_CAPA_API_KEY=

# Add more Azure connections as you add entries to models.yaml, e.g.:
# AZURE_EAST_API_KEY=

# ── Active backend for live queries ───────────────────────────────────────────
# Must match an "id" in models.yaml. Used by the UI and run_query().
# The benchmark (make benchmark) ignores this — it runs all connections.
# Default is "capa" (Azure). Change to "claude-sonnet" for local Anthropic testing.
MODEL_BACKEND=capa

PG_HOST=
PG_PORT=
PG_DBNAME=
PG_USER=
PG_PASSWORD=

# Directory for persistent data (history, cache). Docker/cloud only — do not
# set for local development. docker_run.sh passes -e CANOPY_DATA_DIR=/data.
# Without this set, the app defaults to ~/.canopy and falls back to that path
# if the configured directory cannot be created.
# CANOPY_DATA_DIR=/data

# Hours before cached query results expire and are re-fetched from the model.
# Set to 0 to disable caching. Default: 24.
# CANOPY_CACHE_TTL_HOURS=24

# UI label language: en or es. Controls button labels and status messages only.
# Model responses auto-detect from question language independently. Default: en.
# CANOPY_UI_LANG=en