# Anthropic API
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
# Timeout for Anthropic API calls in seconds (default: 60)
# ANTHROPIC_TIMEOUT=60

# Which backend the registry should use. Only "anthropic" exists right now.
MODEL_BACKEND=anthropic

PG_HOST=
PG_PORT=
PG_DBNAME=
PG_USER=
PG_PASSWORD=

# Directory for persistent data (history). Override in Docker/cloud.
# Mount a persistent volume at this path to survive container restarts.
# CANOPY_DATA_DIR=/data